# Discord-Bot-Token (Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=dein-bot-token

# Ziel-Channel-ID (Discord Entwicklermodus an -> Rechtsklick Channel -> ID kopieren)
DISCORD_CHANNEL_ID=123456789012345678

# Beliebiges, geheimes Passwort – identisch im GitHub-Webhook eintragen.
GITHUB_WEBHOOK_SECRET=ein-langes-zufaelliges-secret

# HTTP-Server, der die GitHub-Webhooks empfängt.
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/github

# Nur Anzeige (Footer / Fallback-Links).
REPO_FULL_NAME=maxnoelp/prostratsix
